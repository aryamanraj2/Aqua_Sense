# ── Gemini API ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./aquasense.db

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=True

# ── File upload ───────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes

# ── ML model ──────────────────────────────────────────────────────────────────
DISEASE_MODEL_PATH=ml/models/fish_disease.keras

# ── Gemini settings ───────────────────────────────────────────────────────────
GEMINI_MODEL=gemini-flash-latest
GEMINI_MAX_TOKENS=8192
GEMINI_TEMPERATURE=0.7

# ── Session management ────────────────────────────────────────────────────────
SESSION_TIMEOUT=3600  # 1 hour in seconds

# ── Sentinel node safety bounds (cognition-tier enforcement) ──────────────────
# Must mirror config.h constants in hardware/firmware/include/config.h
NODE_HEARTBEAT_TIMEOUT=90        # seconds before node marked stale
NODE_OFFLINE_TIMEOUT=300         # seconds before node marked offline
NODE_READING_MAX_AGE=120         # seconds before reading tagged stale

DOSE_MAX_SINGLE_ML=15.0          # max mL per single dose command
DOSE_MIN_INTERVAL_S=600          # min seconds between dose commands per node
DOSE_ROLLING_CAP_ML=40.0         # max mL per node per rolling hour
