#pragma once
/**
 * secrets.h.example — copy to secrets.h (already in .gitignore) and fill in.
 * Include this file in config.h AFTER the defaults to override them.
 *
 * Never commit secrets.h — it stays local to each device's build environment.
 */

// SoftAP credentials (WPA2 — change per deployment)
#undef  SOFTAP_SSID
#undef  SOFTAP_PASS
#define SOFTAP_SSID  "AquaSentinel-<tank-id>"
#define SOFTAP_PASS  "change-me-strong-password"

// Backend URL (laptop IP on the SoftAP subnet)
#undef  BACKEND_URL
#define BACKEND_URL  "http://192.168.4.2:8000/api/v1"

// Per-device node ID (provisioned via NVS at first boot, but can override here)
#undef  DEFAULT_NODE_ID
#define DEFAULT_NODE_ID  "sentinel-<mac-suffix>"
